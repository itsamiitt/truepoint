# Claude Code hook state (not source; per-machine)
.claude/.arch-map-nudge

# Node / Turborepo (the planned monorepo stack — ignored ahead of first code)
node_modules/
dist/
build/
.next/
.turbo/
coverage/

# Env & secrets (never commit real values; .env.example documents the shape)
.env
.env.*
!.env.example

# Deploy-time secrets — generated on the server, never committed.
deploy/keys/

# Drizzle migrations are now GENERATED in dev (`bun run --filter @leadwolf/db generate`) and COMMITTED —
# prod APPLIES them deterministically (no generate at deploy time, which could hang/prompt on the host).
# So packages/db/src/migrations/ is tracked on purpose; do not re-ignore it.

# Next.js generated type reference (per-build, like .next/)
next-env.d.ts

# TypeScript incremental-build state (written by tsc --noEmit with incremental projects)
*.tsbuildinfo
