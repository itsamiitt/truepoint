# LeadWolf — environment shape (documents keys only; never commit real values).
# Validated at boot by packages/config (appEnvSchema). Copy to .env for local dev.

NODE_ENV=development

# ── Auth service boundary (17 / ADR-0016) ───────────────────────────────────────────────────────────
# The dedicated identity origin and the app origins it issues tokens to (same-site under truepoint.in).
AUTH_ORIGIN=https://auth.truepoint.in
# Comma-separated CORS allow-list for /token/* — explicit origins only, NEVER a wildcard.
APP_ORIGINS=https://app.truepoint.in
# Host-only cookie domain for the refresh cookie (scoped to the auth origin).
AUTH_COOKIE_DOMAIN=auth.truepoint.in
# Client-IP binding posture for the cross-domain code (ADR-0016 addendum): prefix (default; same /24·/64,
# robust to dual-stack first-hop drift) | strict (exact normalized IP) | off (rely on PKCE + single-use TTL).
AUTH_BIND_IP=prefix

# Token lifetimes (seconds). Access = in-memory JWT; code = single-use cross-domain handoff.
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_CODE_TTL_SECONDS=60

# JWT signing (asymmetric, EdDSA). Private key signs on auth.*; JWKS publishes the public set.
# In production these come from Secrets Manager (KMS); locally use dev keys.
JWT_SIGNING_KID=dev-2026-06
JWT_PRIVATE_KEY_PEM=
JWT_PUBLIC_KEY_PEM=

# ── Bootstrap platform admin (ADR-0032) ──────────────────────────────────────────────────────────────
# Provisioned by apps/auth bootstrapAdmin.ts. REQUIRED, no default — the seed FAILS CLOSED if either is
# unset. Set real values in .env (never commit) and rotate the password after first login.
BOOTSTRAP_ADMIN_EMAIL=
BOOTSTRAP_ADMIN_PASSWORD=

# ── Data plane ───────────────────────────────────────────────────────────────────────────────────────
DATABASE_URL=postgresql://leadwolf:leadwolf@localhost:5432/leadwolf
# Non-BYPASSRLS application role (RLS enforced); distinct from any privileged admin role.
DATABASE_APP_ROLE=leadwolf_app
REDIS_URL=redis://localhost:6379

# HMAC key for email/domain blind indexes + token hashing (KMS-wrapped in prod).
BLIND_INDEX_KEY=dev-blind-index-key-change-me

# ── Local infra (docker-compose) ─────────────────────────────────────────────────────────────────────
TYPESENSE_URL=http://localhost:8108
TYPESENSE_API_KEY=dev
SMTP_URL=smtp://localhost:1025

# ── Web apps (NEXT_PUBLIC_* are build-inlined + browser-visible; non-secret origins only) ─────────────
# Local dev ports: auth 3000 · api 3001 · web 3002 (override these to http://localhost:<port>).
NEXT_PUBLIC_AUTH_ORIGIN=https://auth.truepoint.in
NEXT_PUBLIC_APP_ORIGIN=https://app.truepoint.in
NEXT_PUBLIC_API_BASE=https://api.truepoint.in
