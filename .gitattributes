# Normalize ALL text files to LF in the index and on checkout (every platform). The repo
# is authored on Windows but deploys to Ubuntu, and the toolchain (Biome, tsc, bun) treats
# LF as canonical — without this, a Windows checkout gets CRLF working-tree files that Biome
# flags as format errors even though git stores LF. eol=lf keeps the working tree == index.
* text=auto eol=lf

# Ensure shell scripts and container files keep LF endings on checkout (incl. on the
# Ubuntu server cloned from a Windows commit) — CRLF would break bash / the shebang.
*.sh text eol=lf
deploy/*.sh text eol=lf
deploy/Caddyfile text eol=lf
Dockerfile text eol=lf
*.yml text eol=lf
*.yaml text eol=lf
