# Copy to .env and fill in. The .env file is gitignored — never commit the real token.

# Strong shared secret. All three terminals present it as: Authorization: Bearer <token>
# Generate one with:  openssl rand -hex 32   (or)   bun -e "console.log(crypto.randomUUID().replaceAll('-','')+crypto.randomUUID().replaceAll('-',''))"
MCP_BEARER_TOKEN=

# Port the bus listens on (bound to 0.0.0.0 so other machines can reach it).
PORT=7333

# Where the JSON state file is written.
COORD_STATE=./coord-state.json
