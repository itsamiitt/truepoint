{
  "name": "leadwolf",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.14",
  "workspaces": ["apps/*", "packages/*"],
  "scripts": {
    "dev": "turbo run dev",
    "build": "turbo run build",
    "typecheck": "turbo run typecheck",
    "test": "bun test",
    "lint": "biome check .",
    "format": "biome format --write .",
    "lint:boundaries": "depcruise apps packages",
    "arch:map": "node .claude/hooks/gen-architecture-map.mjs",
    "db:migrate": "bun run --filter @leadwolf/db migrate",
    "db:seed": "bun run --filter @leadwolf/db seed",
    "dev:admin": "turbo run dev --filter @leadwolf/admin",
    "build:admin": "turbo run build --filter @leadwolf/admin"
  },
  "devDependencies": {
    "@biomejs/biome": "1.9.4",
    "@types/bun": "^1.3.14",
    "dependency-cruiser": "16.10.4",
    "turbo": "2.3.3",
    "typescript": "5.7.2"
  },
  "engines": {
    "bun": ">=1.1.0"
  }
}
