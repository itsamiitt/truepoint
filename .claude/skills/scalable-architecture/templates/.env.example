# .env.example — documents every environment variable this app expects.
# Copy to ".env" and fill in real values. NEVER commit a real .env or any secret (principle #8).
# Code reads these only through the validated config/ module — not process.env scattered around.

# --- Core ---
NODE_ENV=development
PORT=3000

# --- Database ---
DATABASE_URL=postgres://user:password@localhost:5432/app_dev

# --- Auth / sessions ---
SESSION_SECRET=replace-with-a-long-random-string

# --- Third-party APIs (placeholders only) ---
# STRIPE_SECRET_KEY=sk_test_xxx
# OPENAI_API_KEY=sk-xxx
