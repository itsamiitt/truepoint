# Caddy — TLS termination + subdomain routing for the TruePoint preview.
# Caddy automatically provisions and renews Let's Encrypt certificates for each site,
# provided (1) the subdomain's DNS A record points at this server and (2) ports 80+443
# are reachable from the internet (open them in the EC2 Security Group).
#
# Edit the hostnames below if your domain differs. Each site reverse-proxies to a
# container on the internal compose network (service name : container port).

# Global options (must be the FIRST block). ACME contact for Let's Encrypt expiry/policy notices.
{
	email amit@thecloso.com

	# Define which upstreams may be trusted to set X-Forwarded-For, so the auth origin binds the cross-domain
	# code to the REAL client IP (ADR-0016), not a spoofed header. Caddy is the edge here (clients connect
	# directly), so it derives the client IP from the connection and ignores client-sent XFF. Keep this
	# accurate if a load balancer / CDN is ever placed in front (add its range), or dual-stack first-hop
	# drift can make the IP binding reject legitimate logins — see AUTH_BIND_IP (env) for the binding posture.
	servers {
		trusted_proxies static private_ranges
	}
}

# Shared site body, parameterised by the upstream (service:port). Each site below imports it so the
# edge behaviour stays identical across all four subdomains and is defined in exactly one place.
#
#   encode zstd gzip
#     Compress upstream responses at the edge (RC#10). Next.js can only emit gzip; Caddy negotiates the
#     best encoding the client accepts (zstd preferred, gzip fallback) so HTML/JSON/JS shrink on the wire.
#     `encode` is content-type aware: it skips already-compressed media (images, video, fonts, .gz/.br/.zst)
#     and tiny payloads, so there's no harmful double-compression.
#
#   lb_try_duration 5s / lb_try_interval 250ms
#     Cold-start cushion (RC#12). On a single-host deploy a `docker compose up -d` recreates the only
#     container for a service, leaving a brief window where the upstream refuses connections. Without a
#     retry, Caddy turns that connection-refused straight into a 502. These let Caddy retry the dial for
#     up to 5s (every 250ms) so a request that arrives mid-recreate waits for the new container instead of
#     erroring. Caddy only retries when no bytes have been written to the upstream yet, so non-idempotent
#     requests are not silently replayed.
(site_proxy) {
	encode zstd gzip
	reverse_proxy {args[0]} {
		lb_try_duration 5s
		lb_try_interval 250ms
	}
}

auth.truepoint.in {
	import site_proxy auth:3000
}

app.truepoint.in {
	import site_proxy web:3002
}

api.truepoint.in {
	import site_proxy api:3001
}

admin.truepoint.in {
	import site_proxy admin:3003
}

# TruePoint Forge — the data-ops operator console + its capture-ingest/BFF API (ADR-0047; nested).
# The console's browser code calls its BFF with RELATIVE paths (apps/forge publicConfig API_BASE="",
# the same-origin proxy deployment), so /bff/* here routes to forge-api and everything else to the Next
# console. Same-origin means no CORS surface at all — forge-api deliberately ships none. The capture
# ingest + health/metrics surfaces stay on the forge-api.truepoint.in origin below.
forge.truepoint.in {
	encode zstd gzip
	handle /bff/* {
		reverse_proxy forge-api:3005 {
			lb_try_duration 5s
			lb_try_interval 250ms
		}
	}
	handle {
		reverse_proxy forge:3004 {
			lb_try_duration 5s
			lb_try_interval 250ms
		}
	}
}

forge-api.truepoint.in {
	import site_proxy forge-api:3005
}
