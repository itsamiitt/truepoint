# TruePoint — preview deployment environment.
# Copy to the repo root as .env.production and edit the marked values:
#     cp deploy/env.production.template .env.production
#
# Topology: Caddy terminates TLS and routes four subdomains to the services —
#   app.truepoint.in → web   auth.truepoint.in → auth   api.truepoint.in → api   admin.truepoint.in → admin
# Point each subdomain's DNS A record at this server, and edit deploy/Caddyfile if your
# domain differs. Do NOT add :port to these URLs — Caddy serves them on 443.
#
# .env.production holds secrets and is git-ignored (.env.* is in .gitignore). Never commit it.
# These NEXT_PUBLIC_* / *_ORIGIN values are baked into the web bundle at BUILD time —
# if you change them, re-run deploy/deploy.sh to rebuild.

NODE_ENV=production

# ── Public, browser-facing origins (HTTPS via Caddy) ─────────────────────────────
AUTH_ORIGIN=https://auth.truepoint.in
# In-cluster origin the api uses ONLY to fetch the auth JWKS (token verification), keeping that hop OFF the
# public edge: without it the api hairpins out (public DNS → TLS → Caddy → back to the auth container it
# already shares a docker network with) on every protected request. `auth` is the compose service name, 3000
# its internal port. The token's issuer/audience are STILL checked against the PUBLIC AUTH_ORIGIN above — only
# the JWKS fetch moves internal — so plain http is fine here (docker-network traffic). Leave unset to disable.
INTERNAL_AUTH_ORIGIN=http://auth:3000
# CORS + token-audience allow-list for /token/* — include EVERY app origin the IdP issues tokens to: the
# customer app AND the staff console. Comma-separated, explicit origins, never a wildcard.
APP_ORIGINS=https://app.truepoint.in,https://admin.truepoint.in,https://forge.truepoint.in

# ── TruePoint Forge (ADR-0047; nested) ─────────────────────────────────────────────
# The forge console + forge-api share the auth origin (operators sign in as data_ops staff). The pipeline is
# DARK by default (capture + sync egress kill-switches off) until legal sign-off (OQ-2).
FORGE_CAPTURE_ENABLED=false
FORGE_SYNC_EGRESS_ENABLED=false
FORGE_CAPTURE_TENANTS=
FORGE_BLIND_INDEX_KEY=
# Object store for large raw payloads (S3/MinIO). ANTHROPIC_API_KEY drives the extract stage (real spend).
S3_ENDPOINT=
S3_BUCKET=forge-raw-captures
S3_ACCESS_KEY_ID=
S3_SECRET_ACCESS_KEY=
S3_REGION=us-east-1
FORGE_EXTRACT_MODEL=claude-haiku-4-5-20251001
AUTH_COOKIE_DOMAIN=auth.truepoint.in
# Cross-domain code IP binding (ADR-0016 addendum): prefix (default — same /24·/64, tolerates dual-stack
# first-hop drift) | strict (exact normalized IP) | off (rely on PKCE + single-use TTL). If sign-in fails
# with reason=ip_mismatch in the auth logs, try `off`.
AUTH_BIND_IP=prefix
NEXT_PUBLIC_AUTH_ORIGIN=https://auth.truepoint.in
NEXT_PUBLIC_APP_ORIGIN=https://app.truepoint.in
NEXT_PUBLIC_API_BASE=https://api.truepoint.in
# Staff console (admin.truepoint.in) API base — used by the admin feature-flags/provider-configs slices.
# (The other admin slices read NEXT_PUBLIC_API_BASE above; the admin app derives its own origin from the
# browser at runtime, so NEXT_PUBLIC_APP_ORIGIN staying app.* is fine.)
NEXT_PUBLIC_ADMIN_API_BASE=https://api.truepoint.in
# RFC 9457 problem-details `type` namespace shown in API error responses (stable identifier; trailing slash).
ERROR_TYPE_BASE_URL=https://truepoint.in/errors/

# ── Token lifetimes (seconds) ──────────────────────────────────────────────────
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_CODE_TTL_SECONDS=60

# ── JWT signing (EdDSA / Ed25519) ───────────────────────────────────────────────
# Leave the raw multi-line PEMs out of this file (they can't live in a .env). deploy.sh AUTO-GENERATES the
# keypair under deploy/keys/ on first run (and repairs a corrupt/missing one), base64-encodes it, and PERSISTS
# the single-line JWT_PRIVATE_KEY_PEM_B64 / JWT_PUBLIC_KEY_PEM_B64 into THIS file (appended on first deploy).
# Single-line base64 lives safely in a .env and is loaded via compose env_file, so the signing key survives
# every restart / recreate / reboot — not just the deploy.sh run (a shell-only export would vanish on a plain
# `docker compose up -d` → empty key → login 503s). You normally never edit those two lines by hand. A
# post-deploy smoke test fails the deploy if the key can't mint, so broken login never ships silently.
JWT_SIGNING_KID=preview-2026-06

# ── Bootstrap platform admin (ADR-0032) ───────────────────────────────────────────
# REQUIRED — the seed (apps/auth bootstrapAdmin.ts) FAILS CLOSED if unset; there is NO built-in default.
# Use a real admin email + a long random password, and ROTATE the password after first login.
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.example
BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-long-random-secret

# ── Data plane ───────────────────────────────────────────────────────────────────
# Managed Postgres (Neon / RDS). Append ?sslmode=require for Neon. Neon's default string is the
# POOLED (`-pooler`) host — fine for the app (it sets prepare:false). Migrations also set prepare:false
# so the pooled host works, but if you prefer, set DATABASE_MIGRATION_URL to the DIRECT (non-pooler)
# host below and migrations will use it instead.
#
# Paste the provider's string verbatim — quoting is NOT required, even though Neon's ends in
# `&channel_binding=require`. Both readers of this file (compose's env_file at runtime,
# scripts/export-dotenv.sh at build time) take values literally and never shell-interpret them.
#
# NOTE ON PRIVILEGE: migrations CREATE tables, roles, and extensions, so DATABASE_MIGRATION_URL
# must use the database OWNER. The non-privileged, RLS-enforced DATABASE_APP_ROLE below is what
# the running app uses — pointing migrations at it fails with "permission denied".
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require&channel_binding=require
# DATABASE_MIGRATION_URL=postgresql://USER:PASSWORD@DIRECT-HOST/DBNAME?sslmode=require
DATABASE_APP_ROLE=leadwolf_app
REDIS_URL=redis://redis:6379

# CHANGE THIS to a long random string (min 8 chars). HMAC key for blind indexes +
# token hashing — rotating it invalidates existing blind-indexed lookups.
BLIND_INDEX_KEY=change-me-to-a-long-random-string

# ── Search + email ──────────────────────────────────────────────────────────────
TYPESENSE_URL=http://typesense:8108
TYPESENSE_API_KEY=dev
# Transactional email provider: RESEND (chosen 2026-07, AUTH-040/061). INJECT SMTP_URL AS A SECRET — never
# commit the key. Exact value:
#     SMTP_URL=smtps://resend:re_YOUR_API_KEY@smtp.resend.com:465
# The username is the literal "resend"; the password is a Resend API key (re_…). Port 465 = implicit TLS
# (use 587 for STARTTLS if 465 is blocked). No app code changes — mailer.ts sends via nodemailer over SMTP.
# PREREQ (or mail is REJECTED): verify the sending DOMAIN in the Resend dashboard (SPF + DKIM). The From address
# is  TruePoint <no-reply@<AUTH_ORIGIN host>>  (mailer.ts) → no-reply@auth.truepoint.in, so verify that domain.
# Do NOT point this at MailHog / Mailpit / localhost in production — those CAPTURE mail on-box and never deliver
# it, silently breaking password reset / verification / magic links (AUTH-061); the auth mailer emits a loud
# MISCONFIGURED marker if it detects a dev-capture transport. Bounce/complaint handling → the Resend webhook
# (EMAIL_WEBHOOK_SECRET, reuse the M12 ESP webhook pattern) — tracked as 0.2c-bounce.
SMTP_URL=

# ── Optional integrations (leave blank/commented to disable) ────────────────────
# STRIPE_WEBHOOK_SECRET=
# APOLLO_API_KEY=
# ZOOMINFO_API_KEY=
# CLEARBIT_API_KEY=
# TURNSTILE_SECRET=
