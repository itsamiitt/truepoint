# LeadWolf — preview deployment environment.
# Copy to the repo root as .env.production and edit the marked values:
#     cp deploy/env.production.template .env.production
#
# Topology: Caddy terminates TLS and routes three subdomains to the services —
#   app.truepoint.in  → web    auth.truepoint.in → auth    api.truepoint.in → api
# Point each subdomain's DNS A record at this server, and edit deploy/Caddyfile if your
# domain differs. Do NOT add :port to these URLs — Caddy serves them on 443.
#
# .env.production holds secrets and is git-ignored (.env.* is in .gitignore). Never commit it.
# These NEXT_PUBLIC_* / *_ORIGIN values are baked into the web bundle at BUILD time —
# if you change them, re-run deploy/deploy.sh to rebuild.

NODE_ENV=production

# ── Public, browser-facing origins (HTTPS via Caddy) ─────────────────────────────
AUTH_ORIGIN=https://auth.truepoint.in
APP_ORIGINS=https://app.truepoint.in
AUTH_COOKIE_DOMAIN=auth.truepoint.in
# Cross-domain code IP binding (ADR-0016 addendum): prefix (default — same /24·/64, tolerates dual-stack
# first-hop drift) | strict (exact normalized IP) | off (rely on PKCE + single-use TTL). If sign-in fails
# with reason=ip_mismatch in the auth logs, try `off`.
AUTH_BIND_IP=prefix
NEXT_PUBLIC_AUTH_ORIGIN=https://auth.truepoint.in
NEXT_PUBLIC_APP_ORIGIN=https://app.truepoint.in
NEXT_PUBLIC_API_BASE=https://api.truepoint.in
# RFC 9457 problem-details `type` namespace shown in API error responses (stable identifier; trailing slash).
ERROR_TYPE_BASE_URL=https://truepoint.in/errors/

# ── Token lifetimes (seconds) ──────────────────────────────────────────────────
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_CODE_TTL_SECONDS=60

# ── JWT signing (EdDSA / Ed25519) ───────────────────────────────────────────────
# Leave the raw multi-line PEMs out of this file (they can't live in a .env). deploy.sh AUTO-GENERATES the
# keypair under deploy/keys/ on first run (and repairs a corrupt/missing one), base64-encodes it, and PERSISTS
# the single-line JWT_PRIVATE_KEY_PEM_B64 / JWT_PUBLIC_KEY_PEM_B64 into THIS file (appended on first deploy).
# Single-line base64 lives safely in a .env and is loaded via compose env_file, so the signing key survives
# every restart / recreate / reboot — not just the deploy.sh run (a shell-only export would vanish on a plain
# `docker compose up -d` → empty key → login 503s). You normally never edit those two lines by hand. A
# post-deploy smoke test fails the deploy if the key can't mint, so broken login never ships silently.
JWT_SIGNING_KID=preview-2026-06

# ── Bootstrap platform admin (ADR-0032) ───────────────────────────────────────────
# REQUIRED — the seed (apps/auth bootstrapAdmin.ts) FAILS CLOSED if unset; there is NO built-in default.
# Use a real admin email + a long random password, and ROTATE the password after first login.
BOOTSTRAP_ADMIN_EMAIL=admin@yourdomain.example
BOOTSTRAP_ADMIN_PASSWORD=change-me-to-a-long-random-secret

# ── Data plane ───────────────────────────────────────────────────────────────────
# Managed Postgres (Neon / RDS). Append ?sslmode=require for Neon. Neon's default string is the
# POOLED (`-pooler`) host — fine for the app (it sets prepare:false). Migrations also set prepare:false
# so the pooled host works, but if you prefer, set DATABASE_MIGRATION_URL to the DIRECT (non-pooler)
# host below and migrations will use it instead.
DATABASE_URL=postgresql://USER:PASSWORD@HOST/DBNAME?sslmode=require
# DATABASE_MIGRATION_URL=postgresql://USER:PASSWORD@DIRECT-HOST/DBNAME?sslmode=require
DATABASE_APP_ROLE=leadwolf_app
REDIS_URL=redis://redis:6379

# CHANGE THIS to a long random string (min 8 chars). HMAC key for blind indexes +
# token hashing — rotating it invalidates existing blind-indexed lookups.
BLIND_INDEX_KEY=change-me-to-a-long-random-string

# ── Search + email ──────────────────────────────────────────────────────────────
TYPESENSE_URL=http://typesense:8108
TYPESENSE_API_KEY=dev
SMTP_URL=smtp://mailhog:1025

# ── Optional integrations (leave blank/commented to disable) ────────────────────
# STRIPE_WEBHOOK_SECRET=
# APOLLO_API_KEY=
# ZOOMINFO_API_KEY=
# CLEARBIT_API_KEY=
# TURNSTILE_SECRET=
