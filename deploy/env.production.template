# LeadWolf — preview deployment environment.
# Copy to the repo root as .env.production and edit the marked values:
#     cp deploy/env.production.template .env.production
#
# Replace EVERY occurrence of PUBLIC_HOST with your server's public IP or domain
# (e.g. 203.0.113.10 or app.example.com). Do NOT use localhost — the browser must be
# able to reach the API/auth origins from the user's machine.
#
# .env.production holds secrets and is git-ignored (.env.* is in .gitignore). Never commit it.
# These NEXT_PUBLIC_* / *_ORIGIN values are baked into the web bundle at BUILD time —
# if you change them, re-run deploy/deploy.sh to rebuild.

NODE_ENV=production

# ── Public, browser-facing origins ──────────────────────────────────────────────
AUTH_ORIGIN=http://PUBLIC_HOST:3000
APP_ORIGINS=http://PUBLIC_HOST:3002
AUTH_COOKIE_DOMAIN=PUBLIC_HOST
NEXT_PUBLIC_AUTH_ORIGIN=http://PUBLIC_HOST:3000
NEXT_PUBLIC_APP_ORIGIN=http://PUBLIC_HOST:3002
NEXT_PUBLIC_API_BASE=http://PUBLIC_HOST:3001

# ── Token lifetimes (seconds) ──────────────────────────────────────────────────
ACCESS_TOKEN_TTL_SECONDS=900
REFRESH_TOKEN_TTL_SECONDS=2592000
AUTH_CODE_TTL_SECONDS=60

# ── JWT signing (EdDSA / Ed25519) ───────────────────────────────────────────────
# Leave the PEMs out of this file. Run `bash deploy/gen-keys.sh` to create them under
# deploy/keys/; deploy.sh injects them into the auth/api containers at run time.
# Without keys the stack still boots, but login / token signing will not work.
JWT_SIGNING_KID=preview-2026-06

# ── Data plane (hostnames are the compose service names) ────────────────────────
DATABASE_URL=postgresql://leadwolf:leadwolf@postgres:5432/leadwolf
DATABASE_APP_ROLE=leadwolf_app
REDIS_URL=redis://redis:6379

# CHANGE THIS to a long random string (min 8 chars). HMAC key for blind indexes +
# token hashing — rotating it invalidates existing blind-indexed lookups.
BLIND_INDEX_KEY=change-me-to-a-long-random-string

# ── Search + email ──────────────────────────────────────────────────────────────
TYPESENSE_URL=http://typesense:8108
TYPESENSE_API_KEY=dev
SMTP_URL=smtp://mailhog:1025

# ── Optional integrations (leave blank/commented to disable) ────────────────────
# STRIPE_WEBHOOK_SECRET=
# APOLLO_API_KEY=
# ZOOMINFO_API_KEY=
# CLEARBIT_API_KEY=
# TURNSTILE_SECRET=
